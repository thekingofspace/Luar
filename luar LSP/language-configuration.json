{
  "comments": {
    "lineComment": "--",
    "blockComment": ["--[[", "]]"]
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"", "notIn": ["string", "comment"] },
    { "open": "'", "close": "'", "notIn": ["string", "comment"] },
    { "open": "`", "close": "`", "notIn": ["string", "comment"] }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""],
    ["'", "'"],
    ["`", "`"]
  ],
  "autoCloseBefore": ";:.,=}])> \n\t",
  "indentationRules": {
    "increaseIndentPattern": "^((?!--).)*((\\b(then|do|else)\\b)|(\\bfunction\\b.*\\(.*\\))|(\\b(class|interface|case|default)\\b.*)|(\\{\\s*)|(\\(\\s*))\\s*(--.*)?$",
    "decreaseIndentPattern": "^\\s*((\\bend\\b)|(\\belse\\b)|(\\belseif\\b)|(\\buntil\\b)|\\}|\\))"
  },
  "onEnterRules": [
    {
      "comment": "Indent the body after a function header, dedent the closing end",
      "beforeText": "^\\s*(?:(?:pub|local|const|public|private|protected|static|abstract|final|override)\\s+)*function\\s*[\\w.:]*\\s*\\([^)]*\\)\\s*$",
      "afterText": "^\\s*end\\b",
      "action": { "indent": "indentOutdent" }
    },
    {
      "beforeText": "\\b(?:then|do|else)\\s*$",
      "afterText": "^\\s*(?:end|else|elseif)\\b",
      "action": { "indent": "indentOutdent" }
    }
  ]
}
