{
  "name": "luar-lang",
  "displayName": "LUAR",
  "description": "Language support for LUAR, including the file icon for .luar files.",
  "version": "0.14.0",
  "publisher": "luar",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:luar"
  ],
  "scripts": {
    "build:server": "cargo build --release --manifest-path server/Cargo.toml && node -e \"require('fs').copyFileSync('server/target/release/' + (process.platform==='win32'?'luar-lsp-server.exe':'luar-lsp-server'), 'bin/' + (process.platform==='win32'?'server.exe':'luar-lsp-server'))\"",
    "build:client": "esbuild client/src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node",
    "build": "npm run build:server && npm run build:client",
    "vscode:prepublish": "npm run build:client"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.75.0",
    "esbuild": "^0.21.0",
    "typescript": "^5.4.0"
  },
  "contributes": {
    "languages": [
      {
        "id": "luar",
        "aliases": [
          "LUAR",
          "luar"
        ],
        "extensions": [
          ".luar",
          ".luard"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/laur_logo.png",
          "dark": "./icons/laur_logo.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "luar",
        "scopeName": "source.luar",
        "path": "./syntaxes/luar.tmLanguage.json"
      }
    ],
    "configurationDefaults": {
      "editor.semanticTokenColorCustomizations": {
        "enabled": true,
        "rules": {
          "class": "#DCDCAA"
        }
      },
      "editor.tokenColorCustomizations": {
        "textMateRules": [
          {
            "scope": "constant.language.luar",
            "settings": {
              "foreground": "#569CD6"
            }
          },
          {
            "scope": "support.type.luar",
            "settings": {
              "foreground": "#4EC9B0"
            }
          },
          {
            "scope": "support.class.global.luar",
            "settings": {
              "foreground": "#4FC1FF"
            }
          },
          {
            "scope": "entity.name.type.class.luar",
            "settings": {
              "foreground": "#DCDCAA"
            }
          },
          {
            "scope": "constant.other.enum.luar",
            "settings": {
              "foreground": "#4FC1FF"
            }
          }
        ]
      },
      "[luar]": {
        "editor.wordBasedSuggestions": "off",
        "editor.tabSize": 4,
        "editor.insertSpaces": true
      }
    }
  }
}
