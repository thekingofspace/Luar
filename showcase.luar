--#disable UnusedVariable UnusedLoopVariable UnusedParameter Redeclaration
-- ===========================================================================
--  LUAR feature showcase
--  A tour of (nearly) every language feature, written to actually run.
-- ===========================================================================

-- ---------------------------------------------------------------------------
--  1. Variables, constants, and type annotations
-- ---------------------------------------------------------------------------
local greeting: string = "hello"
const PI: number = 3.14159
local flag = true                 -- type is inferred
local nothing = nil
pub local shared = "visible to importers"   -- pub makes it a module export

-- literal-union type: only these two strings are allowed
local mode: "on" | "off" = "on"

-- ---------------------------------------------------------------------------
--  2. Numbers, strings, and operators
-- ---------------------------------------------------------------------------
local sum = 2 + 3 * 4 - 1
local power = 2 ^ 8
local remainder = 17 % 5
local floatDiv = 7 / 2
local concatenated = "foo" .. "bar" .. tostring(42)
local length = #"hello"            -- 5
local isEqual = (1 == 1) and (2 ~= 3) and not false

print("sum:", sum, "power:", power, "len:", length, "eq:", isEqual)

-- ---------------------------------------------------------------------------
--  3. String forms: escapes, single quotes, multiline, interpolation
-- ---------------------------------------------------------------------------
local escaped = "line1\nline2\ttabbed \"quoted\" \\ backslash"
local single = 'single quotes'
local multiline = [[
this is a
multi-line string
]]
local name = "world"
local interpolated = `hello {name}, 2 + 2 = {2 + 2}`
print(interpolated)

-- ---------------------------------------------------------------------------
--  4. Tables: arrays, maps, nesting
-- ---------------------------------------------------------------------------
local array = {10, 20, 30}
local map = { x = 1, y = 2, label = "origin" }
local nested = { points = { {x = 0, y = 0}, {x = 1, y = 1} } }
print("array[2]:", array[2], "map.x:", map.x, "nested:", nested.points[2].x)

-- ---------------------------------------------------------------------------
--  5. Control flow: if / elseif / else
-- ---------------------------------------------------------------------------
local function classify(n: number): string
    if n < 0 then
        return "negative"
    elseif n == 0 then
        return "zero"
    else
        return "positive"
    end
end
print("classify(-3):", classify(-3), "classify(0):", classify(0))

-- ---------------------------------------------------------------------------
--  6. Loops: numeric for, generic for, while, break
-- ---------------------------------------------------------------------------
local total = 0
for i = 1, 5 do
    total = total + i
end

for index, value in ipairs(array) do
    total = total + value
end

for key, value in pairs(map) do
    -- iterate keys of a map
    total = total + 0
end

local countdown = 3
while countdown > 0 do
    countdown = countdown - 1
    if countdown == 1 then
        break
    end
end
print("total:", total, "countdown:", countdown)

-- ---------------------------------------------------------------------------
--  7. switch / case / default
-- ---------------------------------------------------------------------------
local function describe(s: string): string
    local result = "unknown"
    switch(s)
        case "a"
            result = "first"
        end
        case "b"
            result = "second"
        end
        default
            result = "other"
        end
    end
    return result
end
print("describe(b):", describe("b"), "describe(z):", describe("z"))

-- ---------------------------------------------------------------------------
--  8. Functions: varargs, multiple returns, anonymous, closures
-- ---------------------------------------------------------------------------
local function variadic(...)
    local count = 0
    for _, v in ipairs({...}) do
        count = count + 1
    end
    return count
end

local function minMax(a: number, b: number): (number, number)
    if a < b then
        return a, b
    end
    return b, a
end

local lo, hi = minMax(9, 4)

local function makeCounter()
    local n = 0
    return function()
        n = n + 1
        return n
    end
end
local next = makeCounter()
print("variadic:", variadic(1, 2, 3), "lo/hi:", lo, hi, "counter:", next(), next())

-- ---------------------------------------------------------------------------
--  9. Type aliases, structs, arrays, function types, type functions
-- ---------------------------------------------------------------------------
type Vector2 = { x: number, y: number }
type Numbers = {number}
type Transform = (v: Vector2) -> Vector2
type NameOfPlayer = classof<Player>

local origin: Vector2 = { x = 0, y = 0 }
local scores: Numbers = {100, 95, 80}

-- ---------------------------------------------------------------------------
--  10. Enums (with and without explicit values); enum used as a type
-- ---------------------------------------------------------------------------
enum Color { Red Green Blue }
enum Color {Purple}
enum Status { Active = 10 Idle Banned = 99 }

local favourite: Color = Color.Green
print("Color.Blue:", Color.Blue, "Status.Idle:", Status.Idle)

-- ---------------------------------------------------------------------------
--  11. Interfaces
-- ---------------------------------------------------------------------------
interface Drawable {
    function draw()
}

-- ---------------------------------------------------------------------------
--  12. Classes: fields, access control, constructor, methods, getters,
--      setters, static members, operator overloading
-- ---------------------------------------------------------------------------
class Player implements Drawable {
    public Name: string = "Anon"
    private health: number = 100
    static population: number = 0

    constructor(name)
        self.Name = name
        Player.population = Player.population + 1
    end

    function draw()
        print("drawing player", self.Name)
    end

    function damage(amount: number)
        self.health = self.health - amount
    end

    get hp(): number
        return self.health
    end

    set hp(value: number)
        self.health = value
    end

    operator +(other)
        return Player(self.Name .. "+" .. other.Name)
    end

    static function count(): number
        return Player.population
    end
}

local p1 = Player("Alice")
local p2 = Player("Bob")
p1:damage(30)
p1.hp = p1.hp + 5             -- setter then getter
local combined = p1 + p2      -- operator +
print("p1.hp:", p1.hp, "combined:", combined.Name, "population:", Player.count())

-- ---------------------------------------------------------------------------
--  13. Inheritance, abstract/final/override, super
-- ---------------------------------------------------------------------------
abstract class Shape {
    abstract function area(): number end

    function describe(): string
        return "a shape with area " .. tostring(self:area())
    end
}

class Circle extends Shape {
    public radius: number = 1

    constructor(r)
        self.radius = r
    end

    override function area(): number
        return PI * self.radius * self.radius
    end
}

local c = Circle(2)
print(c:describe(), "instanceof Shape:", instanceof(c, Shape))

-- ---------------------------------------------------------------------------
--  13b. Mixins: compose reusable methods into a class without inheritance
-- ---------------------------------------------------------------------------
-- A mixin is just a class whose members are folded into any class that lists it
-- with `mixin`. A class can mix in several at once (comma-separated), and the
-- mixed-in methods run against the host instance's own fields via `self`.
class Loggable {
    function log(message: string)
        print("[" .. self.tag .. "] " .. message)
    end
}

class Identifiable {
    function id(): string
        return "#" .. tostring(self.serial)
    end
}

class Service mixin Loggable, Identifiable {
    public tag: string = "svc"
    public serial: number = 0

    constructor(tag, serial)
        self.tag = tag
        self.serial = serial
    end
}

local svc = Service("auth", 7)
svc:log("started " .. svc:id())     -- log() and id() both come from mixins

-- ---------------------------------------------------------------------------
--  14. Metatables and metamethods on plain tables
-- ---------------------------------------------------------------------------
local base = { greet = function(self) return "hi from base" end }
local obj = setmetatable({}, { __index = base })
print("metatable __index:", obj:greet())

local vecMeta = {}
vecMeta.__add = function(a, b) return { x = a.x + b.x, y = a.y + b.y } end
local va = setmetatable({ x = 1, y = 2 }, vecMeta)
local vb = setmetatable({ x = 3, y = 4 }, vecMeta)
local vc = va + vb
print("vec add:", vc.x, vc.y)

-- ---------------------------------------------------------------------------
--  15. Error handling with pcall
-- ---------------------------------------------------------------------------
local ok, err = pcall(function()
    local broken = nil
    return broken()           -- attempt to call nil triggers a runtime error
end)
print("pcall ok:", ok, "err:", err)

-- ---------------------------------------------------------------------------
--  16. Standard library: math, string, table
-- ---------------------------------------------------------------------------
print("math:", math.floor(3.7), math.max(1, 9, 4), math.sqrt(16))
print("string:", string.upper("abc"), string.sub("hello", 1, 3), string.len("hello"))

local list = {3, 1, 2}
table.insert(list, 4)
table.sort(list)
print("table:", table.concat(list, ","), "#list:", #list)

-- ---------------------------------------------------------------------------
--  17. Built-in reflection helpers
-- ---------------------------------------------------------------------------
print("type():", type(42), type("s"), type({}), type(print))
print("classname:", classname(p1), "isabstract(Shape):", isabstract(Shape))
print("tonumber:", tonumber("123") + 1)

-- ---------------------------------------------------------------------------
--  18. Casts
-- ---------------------------------------------------------------------------
local anything = nil :: any
local asString = (42 :: any) :: string

print("=== showcase complete ===")
