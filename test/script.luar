--#disable UnusedVariable
enum GameState {
  Ready
  NotReady
  Pending
}

class MainGame extends MonoBehaviour {
  private State:GameState = GameState.NotReady

  function Start()
    self.GameState = GameState.Ready
  end

  function Update()
    print("ran")
  end
}

spawn(MainGame)
while true do
  run(1)
end